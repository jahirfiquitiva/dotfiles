// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-cmd-l": "editor::Format",
      "cmd-d": "editor::DuplicateLineDown",
      "alt-shift-up": "editor::MoveLineUp",
      "alt-shift-down": "editor::MoveLineDown",
      "cmd-shift-e": "project_panel::ToggleFocus"
    }
  },
  {
    "bindings": {
      "ctrl-alt-cmd-shift-i": "edit_prediction::ToggleMenu"
    }
  },
  {
    "unbind": {
      "ctrl-cmd-i": "edit_prediction::ToggleMenu"
    }
  },
  {
    "bindings": {
      "ctrl-cmd-i": "agent::NewThread"
    }
  },
  {
    "context": "AgentPanel && acp_thread",
    "unbind": {
      "alt-cmd-t": "agent::NewThread"
    }
  }
]
