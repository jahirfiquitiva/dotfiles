# Based on Mathias Bynens' config
# https://github.com/mathiasbynens/dotfiles/blob/main/.gitconfig
#
# Uses difftastic for better diff
# https://difftastic.wilfred.me.uk/installation.html
[user]
	email = jahir.fiquitiva@gmail.com
	name = Jahir Fiquitiva
[core]
	editor = nano
	ignorecase = false
	excludesFile = ~/.gitignore
        # Make `git rebase` safer on macOS.
	# More info: <http://www.git-tower.com/blog/make-git-rebase-safe-on-osx/>
	trustctime = false
	# Prevent showing files whose names contain non-ASCII symbols as unversioned.
	# http://michael-kuehnel.de/git/2014/11/21/git-mac-osx-and-german-umlaute.html
	precomposeunicode = false
	# Speed up commands involving untracked files such as `git status`.
	# https://git-scm.com/docs/git-update-index#_untracked_cache
	untrackedCache = true
[alias]
	add-commit = !git add . && git commit
[apply]
	# Detect whitespace errors when applying a patch.
	whitespace = fix
[branch]
	# Show most recently changed branches first.
	sort = -committerdate
[credential]
	helper = osxkeychain
[color]
        ui = auto
        status = auto
        branch = auto
[color "branch"]
	current = yellow reverse
	remote = cyan
[color "diff"]
	meta = yellow bold
	frag = magenta bold # line info
	old = red # deletions
	new = green # additions
[color "status"]
	added = green
	changed = yellow
	untracked = cyan
[format]
        pretty = oneline
[init]
        defaultbranch = main
[pull]
        rebase = false
[push]
	# https://git-scm.com/docs/git-config#git-config-pushdefault
	default = simple
	# Make `git push` push relevant annotated tags when pushing branches out.
	followTags = true
[merge]
	# Include summaries of merged commits in newly created merge commit messages
	log = true
[diff]
        external = difft
        tool = difftastic
        # Detect copies as well as renames.
	renames = copies
[difftool]
        prompt = false
[difftool "difftastic"]
        cmd = difft "$LOCAL" "$REMOTE"
# Use a pager for large output, just like other git commands.
[pager]
        difftool = true
[http]
        postBuffer = 157286400
[commit]
	gpgsign = true
[help]
	# Automatically correct and execute mistyped commands.
	autocorrect = 1
[user]
  signingkey = ssh-ed25519 abc123
[gpg]
  format = ssh
[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
